# download-all.sh — переменные окружения для локального запуска (с мака).
# Скопируй в .env и заполни:  cp .env.example .env
# .env уже в .gitignore (секреты не попадут в коммит); этот шаблон — нет.

# ── PostgreSQL (удалённый сервер; с мака — на VPS/доступный инстанс) ──
# Скрипт по умолчанию использует 192.168.10.7:15432; здесь можно перенаправить.
PGHOST=...
PGPORT=15432
PGUSER=postgres
PG_PWD=...
# Имя БД фиксировано в -PG.yaml (wb_data_prod) — не переопределяется через env,
# оставлено для справки / ручных проверок.
PGDATABASE=wb_data_prod

# ── WB API ──
# Имена соответствуют api_key_env / api_key: "${...}" в cmd/.configs/download-all/*-PG.yaml.
WB_API_KEY=...                       # prices, stocks-v2, stock-history, stock-history-metrics, promotion-v2; FALLBACK для sales-finance endpoint при 401 "token scope not allowed"
WB_API_CONTENT_KEY=...               # cards-v2 (api_key_env: WB_API_CONTENT_KEY)
WB_API_ANALYTICS_AND_PROMO_KEY=...   # campaigns, funnel-*, region-sales, penalties, stock-products, whremains, promotion-v2
WB_STAT=...                          # orders, opsales, sales-finance (стартовый токен; при 401 scope переключается на WB_API_KEY)

# ── 1C ──
ONEC_API_URL=...         # 1C catalog (download-1c-data-v2)
ONEC_PIM_URL=...         # 1C PIM    (download-1c-data-v2)
ONEC_API_REST_URL=...    # 1C rests  (download-1c-rests-v2)
